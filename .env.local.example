# --- Konfiguracja wysyłki e-mail (formularze wyceny i kontaktu) ---
# Skopiuj ten plik do .env.local i uzupełnij wartości.
#
# Dla Gmaila:
#   1. Włącz weryfikację dwuetapową na koncie zentiq.kontakt@gmail.com
#   2. Wygeneruj "Hasło aplikacji": https://myaccount.google.com/apppasswords
#   3. Wklej je jako MAIL_PASS (16 znaków, bez spacji)

MAIL_USER=zentiq.kontakt@gmail.com
MAIL_PASS=twoje-haslo-aplikacji

# Opcjonalne (mają sensowne wartości domyślne):
MAIL_TO=zentiq.kontakt@gmail.com
# MAIL_FROM=zentiq.kontakt@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
